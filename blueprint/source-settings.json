{
  "name": "Builder-Agnostic Builder Blueprint",
  "version": "1.0.0",
  "philosophy": {
    "builderAgnostic": true,
    "nativeBuilderFirst": true,
    "externalCssByDefault": false,
    "customCssByDefault": false,
    "classNaming": "shallow-bem",
    "globalHtmlElementStyling": false
  },
  "environment": {
    "rootFontSizePercent": 62.5,
    "rootPx": 10,
    "remAssumption": "1rem = 10px"
  },
  "fluidScale": {
    "viewportMinPx": 360,
    "viewportMaxPx": 1366,
    "formula": {
      "slope": "(max - min) / (viewportMax - viewportMin) * 100",
      "intercept": "min - slope * viewportMin / 100",
      "css": "clamp(min, calc(intercept + slope * 1vw), max)"
    }
  },
  "sourceSettings": {
    "spacing": {
      "baseSpaceMinPx": 24,
      "baseSpaceMaxPx": 30,
      "mobileSpaceScale": 1.333,
      "desktopSpaceScale": 1.5,
      "sectionSpaceMinPx": 48,
      "sectionSpaceMaxPx": 90,
      "gutterMinPx": 16,
      "gutterMaxPx": 80,
      "contentWidthPx": 1400
    },
    "typography": {
      "baseTextMinPx": 16,
      "baseTextMaxPx": 18,
      "textScaleMin": 1.2,
      "textScaleMax": 1.333,
      "baseHeadingMinPx": 18,
      "baseHeadingMaxPx": 20,
      "headingScaleMin": 1.2,
      "headingScaleMax": 1.333,
      "h1MaxPx": 72
    },
    "radius": {
      "radiusXsMinPx": 2,
      "radiusXsMaxPx": 4,
      "radiusSMinPx": 4,
      "radiusSMaxPx": 6,
      "radiusMMinPx": 8,
      "radiusMMaxPx": 12,
      "radiusLMinPx": 12,
      "radiusLMaxPx": 20,
      "radiusXlMinPx": 16,
      "radiusXlMaxPx": 32
    }
  },
  "coreTokens": {
    "colors": {
      "primary": {
        "cssName": "--primary",
        "defaultValue": "oklch(18% 0.03 260)",
        "role": "dark brand/action color"
      },
      "secondary": {
        "cssName": "--secondary",
        "defaultValue": "oklch(46% 0.03 260)",
        "role": "muted support color"
      },
      "accent": {
        "cssName": "--accent",
        "defaultValue": "oklch(62% 0.15 255)",
        "role": "restrained highlight/accent color"
      },
      "base": {
        "cssName": "--base",
        "defaultValue": "oklch(99% 0.003 260)",
        "role": "main light background"
      },
      "surface": {
        "cssName": "--surface",
        "defaultValue": "oklch(96% 0.006 260)",
        "role": "subtle raised or grouped surface"
      },
      "shade": {
        "cssName": "--shade",
        "defaultValue": "oklch(13% 0.02 260)",
        "role": "main dark text/surface"
      },
      "borderColor": {
        "cssName": "--border-color",
        "defaultValue": "oklch(90% 0.01 260)",
        "role": "default neutral border"
      },
      "white": {
        "cssName": "--white",
        "defaultValue": "oklch(100% 0 0)",
        "role": "absolute white"
      },
      "black": {
        "cssName": "--black",
        "defaultValue": "oklch(0% 0 0)",
        "role": "absolute black"
      }
    },
    "spacing": [
      "--space-xs",
      "--space-s",
      "--space-m",
      "--space-l",
      "--space-xl",
      "--space-xxl",
      "--section-space",
      "--gutter",
      "--content-width"
    ],
    "typography": [
      "--font-heading",
      "--font-text",
      "--font-weight-heading",
      "--font-weight-text",
      "--h1",
      "--h1-line-height",
      "--h2",
      "--h2-line-height",
      "--h3",
      "--h3-line-height",
      "--h4",
      "--h4-line-height",
      "--h5",
      "--h5-line-height",
      "--h6",
      "--h6-line-height",
      "--text-xs",
      "--text-s",
      "--text-m",
      "--text-l",
      "--text-xl",
      "--text-xxl",
      "--text-line-height"
    ],
    "shapeAndBorder": [
      "--radius-xs",
      "--radius-s",
      "--radius-m",
      "--radius-l",
      "--radius-xl",
      "--border-width",
      "--border-color"
    ],
    "shadow": [
      "--shadow-xs",
      "--shadow-s",
      "--shadow-m",
      "--shadow-l",
      "--shadow-xl"
    ],
    "focus": [
      "--focus-color",
      "--focus-width",
      "--focus-offset"
    ],
    "transition": [
      "--transition-duration",
      "--transition-timing",
      "--transition-delay"
    ]
  },
  "classes": {
    "layout": [
      "section",
      "container"
    ],
    "navigation": [
      "nav",
      "nav__inner",
      "nav__brand",
      "nav__menu",
      "nav__actions"
    ],
    "hero": [
      "hero",
      "hero__inner",
      "hero__content",
      "hero__media"
    ],
    "footer": [
      "footer",
      "footer__inner",
      "footer__nav"
    ],
    "typography": [
      "h1",
      "h2",
      "h3",
      "h4",
      "h5",
      "h6",
      "text"
    ]
  }
}
